import seaborn as sns
from collections import Counter

from sklearn.model_selection import train_test_split
from sklearn.preprocessing import StandardScaler, LabelEncoder
from sklearn.decomposition import PCA
from sklearn.utils.class_weight import compute_class_weight
from sklearn.metrics import classification_report, confusion_matrix

import tensorflow as tf
from tensorflow.keras import layers, models, regularizers
from tensorflow.keras.callbacks import EarlyStopping

RANDOM_SEED = 42
np.random.seed(RANDOM_SEED)
tf.random.set_seed(RANDOM_SEED)

# ---------- User paths (adjust if needed) ----------
DATA_CSV = "/content/processed_dataset/final_pca_dataset.csv"   # <- your PCA CSV
OUT_DIR = "/content/processed_dataset/cnn_output"
os.makedirs(OUT_DIR, exist_ok=True)

# ---------- 1) Load dataframe ----------
df = pd.read_csv(DATA_CSV)
print("Loaded dataframe shape:", df.shape)
print("Columns (sample):", df.columns[:8].tolist())

# ensure label columns exist
if 'label' not in df.columns:
    raise RuntimeError("CSV must contain a 'label' column (string).")

# ensure label_encoded exists or create it
if 'label_encoded' not in df.columns:
    le = LabelEncoder()
    df['label_encoded'] = le.fit_transform(df['label'])
else:
    le = LabelEncoder()
    le.fit(df['label'])  # ensure mapping is consistent

print("Label classes:", list(le.classes_))
n_classes = len(le.classes_)

# ---------- 2) Group handling for grouped stratified split ----------
# Preferred: if 'group' column exists (recording file names) use it.
if 'group' in df.columns and df['group'].notna().any():
    groups = df['group'].astype(str)
    print("Using existing 'group' column.")
else:
    # fallback: try to use file-like column names that we may have earlier ("orig_file" or similar)
    alt_group_cols = [c for c in df.columns if 'file' in c.lower() or 'orig' in c.lower()]
    if alt_group_cols:
        groups = df[alt_group_cols[0]].astype(str)
        df['group'] = groups
        print(f"Using column '{alt_group_cols[0]}' as group.")
    else:
        # final fallback: create heuristic groups by label contiguous chunks (tunable)
        chunk_size = 20   # adjust if you know approximate block size per recording
        df['group'] = df.groupby('label').cumcount() // chunk_size
        df['group'] = df['label'].astype(str) + "_" + df['group'].astype(str)
        groups = df['group']
        print("No group column found → created heuristic groups (change chunk_size if needed).")

df['group'] = df['group'].astype(str)
groups = df['group'].values
print("Unique groups:", len(np.unique(groups)))

# Create group-level label for stratification: use the dominant label in each group
group_df = df[['group', 'label_encoded']].groupby('group')['label_encoded'].agg(lambda x: Counter(x).most_common(1)[0][0]).reset_index()
group_df.columns = ['group', 'group_label']
# Map back to sample-level
group_label_map = dict(zip(group_df['group'], group_df['group_label']))

unique_groups = group_df['group'].values
group_labels = group_df['group_label'].values

# ---------- 3) Stratified grouped split (train/test groups) ----------
from sklearn.model_selection import train_test_split
train_groups, test_groups = train_test_split(
    unique_groups,
    test_size=0.20,
    random_state=RANDOM_SEED,
    stratify=group_labels
)

train_mask = df['group'].isin(train_groups)
test_mask = df['group'].isin(test_groups)

print("Train groups:", len(train_groups), "Test groups:", len(test_groups))
print("Train samples:", train_mask.sum(), "Test samples:", test_mask.sum())

# ---------- 4) Select features (PCA features created earlier) ----------
# If your CSV contains PC_ columns (PCA output), use them; otherwise use all numeric except labels/groups
pc_cols = [c for c in df.columns if c.startswith("PC_")]
if len(pc_cols) == 0:
    # fallback - take numeric features except label/label_encoded/rms etc.
    non_feat = {'label','label_encoded','group'}
    pc_cols = [c for c in df.columns if np.issubdtype(df[c].dtype, np.number) and c not in non_feat]

print("Using feature columns count:", len(pc_cols))

X = df[pc_cols].values
y = df['label_encoded'].values

# split by masks
X_train_raw = X[train_mask.values]
y_train = y[train_mask.values]
X_test_raw = X[test_mask.values]
y_test = y[test_mask.values]

print("Train shape:", X_train_raw.shape, "Test shape:", X_test_raw.shape)
print("Train label counts:", np.bincount(y_train), "Test label counts:", np.bincount(y_test))

# ---------- 5) Scale + PCA (fit ON TRAIN ONLY) ----------
scaler = StandardScaler()
X_train_scaled = scaler.fit_transform(X_train_raw)
X_test_scaled = scaler.transform(X_test_raw)

# PCA: keep e.g. 0.95 variance or set fixed n_components
pca = PCA(n_components=0.95, svd_solver='auto', random_state=RANDOM_SEED)
X_train_pca = pca.fit_transform(X_train_scaled)
X_test_pca = pca.transform(X_test_scaled)
print("After PCA: train", X_train_pca.shape, "test", X_test_pca.shape, "n_components:", pca.n_components_)

# ---------- 6) Prepare CNN inputs (reshape: timesteps, channels=1) ----------
# 1D CNN expects shape (samples, timesteps, channels)
X_train_cnn = X_train_pca[..., np.newaxis].astype(np.float32)
X_test_cnn = X_test_pca[..., np.newaxis].astype(np.float32)

print("CNN input shape:", X_train_cnn.shape)

# ---------- 7) (optional) simple augmentation: add small gaussian noise to training set ----------
def augment_noise(X, y, times=1, sigma=0.01):
    if times <= 0: return X, y
    Xs = [X]
    ys = [y]
    for _ in range(times):
        noise = np.random.normal(0, sigma, X.shape).astype(np.float32)
        Xs.append(X + noise)
        ys.append(y.copy())
    X_aug = np.vstack(Xs)
    y_aug = np.concatenate(ys)
    return X_aug, y_aug

# tune times/sigma as you like. Here we add one noisy copy (final size = 2x)
X_train_cnn, y_train = augment_noise(X_train_cnn, y_train, times=1, sigma=0.02)
print("After augmentation train shape:", X_train_cnn.shape)

# ---------- 8) Class weights ----------
class_weights_vals = compute_class_weight('balanced', classes=np.unique(y_train), y=y_train)
class_weights = dict(enumerate(class_weights_vals))
print("Class weights:", class_weights)

# ---------- 9) Build a compact 1D-CNN model ----------
tf.keras.backend.clear_session()
n_timesteps = X_train_cnn.shape[1]
n_channels = X_train_cnn.shape[2]

model = models.Sequential([
    layers.Input(shape=(n_timesteps, n_channels)),
    layers.Conv1D(32, kernel_size=3, activation='relu', padding='same'),
    layers.BatchNormalization(),
    layers.MaxPool1D(pool_size=2),

    layers.Conv1D(64, kernel_size=3, activation='relu', padding='same'),
    layers.BatchNormalization(),
    layers.MaxPool1D(pool_size=2),

    layers.Conv1D(128, kernel_size=3, activation='relu', padding='same'),
    layers.BatchNormalization(),
    layers.GlobalAveragePooling1D(),

    layers.Dense(64, activation='relu', kernel_regularizer=regularizers.l2(1e-4)),
    layers.Dropout(0.4),
    layers.Dense(n_classes, activation='softmax')
])

model.compile(optimizer='adam', loss='sparse_categorical_crossentropy', metrics=['accuracy'])
model.summary()

# ---------- 10) Fit with early stopping ----------
es = EarlyStopping(monitor='val_loss', patience=10, restore_best_weights=True, verbose=1)

history = model.fit(
    X_train_cnn, y_train,
    validation_data=(X_test_cnn, y_test),
    epochs=100,
    batch_size=32,
    class_weight=class_weights,
    callbacks=[es],
    verbose=2
)

# ---------- 11) Evaluate and report ----------
test_loss, test_acc = model.evaluate(X_test_cnn, y_test, verbose=0)
print(f"\nTest Loss: {test_loss:.4f}   Test Acc: {test_acc:.4f}")

y_pred_probs = model.predict(X_test_cnn)
y_pred = np.argmax(y_pred_probs, axis=1)

# ensure labels parameter correct length (list of integers)
labels_for_report = list(range(n_classes))
print("\nClassification Report:")
print(classification_report(y_test, y_pred, labels=labels_for_report, target_names=list(le.classes_)))

cm = confusion_matrix(y_test, y_pred, labels=labels_for_report)
plt.figure(figsize=(6,5))
sns.heatmap(cm, annot=True, fmt='d', xticklabels=le.classes_, yticklabels=le.classes_, cmap='Blues')
plt.xlabel("Predicted"); plt.ylabel("True"); plt.title("Confusion Matrix")
plt.show()

# ---------- 12) Save model + scaler + pca ----------
model_path = os.path.join(OUT_DIR, "cnn_model.keras")
model.save(model_path)   # native keras format
import joblib
joblib.dump(scaler, os.path.join(OUT_DIR, "scaler.joblib"))
joblib.dump(pca, os.path.join(OUT_DIR, "pca.joblib"))
print("Saved model and preprocessing to:", OUT_DIR)
# ====================== IMPORTS ======================
import xgboost as xgb
from sklearn.model_selection import StratifiedKFold, cross_val_score, train_test_split
from sklearn.metrics import accuracy_score
import matplotlib.pyplot as plt
import numpy as np

# ====================== PARAMETERS ======================
n_splits = 5  # 5-fold CV
random_state = 42

# ====================== MODEL PARAMETERS ======================
num_classes = len(np.unique(y))
xgb_model = xgb.XGBClassifier(
    n_estimators=150,       # fewer trees
    max_depth=2,            # shallow trees
    learning_rate=0.1,
    subsample=0.8,
    colsample_bytree=0.8,
    reg_alpha=0.5,          # L1 regularization
    reg_lambda=1.0,         # L2 regularization
    seed=random_state,
    use_label_encoder=False,
    eval_metric="mlogloss"
)

# ====================== K-FOLD CROSS-VALIDATION ======================
skf = StratifiedKFold(n_splits=n_splits, shuffle=True, random_state=random_state)
cv_scores = []

for fold, (train_idx, val_idx) in enumerate(skf.split(X, y), 1):
    X_train_fold, X_val_fold = X[train_idx], X[val_idx]
    y_train_fold, y_val_fold = y[train_idx], y[val_idx]

    xgb_model.fit(
        X_train_fold, y_train_fold,
        eval_set=[(X_val_fold, y_val_fold)],
        early_stopping_rounds=20,
        verbose=False
    )

    val_pred = xgb_model.predict(X_val_fold)
    acc = accuracy_score(y_val_fold, val_pred)
    cv_scores.append(acc)
    print(f"Fold {fold} Accuracy: {acc*100:.2f}%")

print(f"\n✅ Mean CV Accuracy: {np.mean(cv_scores)*100:.2f}%")
print(f"Std Dev CV Accuracy: {np.std(cv_scores)*100:.2f}%")

# ====================== TRAIN FINAL MODEL ON FULL TRAIN DATA ======================
X_train_final, X_test_final, y_train_final, y_test_final = train_test_split(
    X, y, test_size=0.2, random_state=random_state, stratify=y
)

xgb_model.fit(
    X_train_final, y_train_final,
    eval_set=[(X_test_final, y_test_final)],
    early_stopping_rounds=20,
    verbose=False
)

# Predict on test set
y_pred_final = xgb_model.predict(X_test_final)
test_acc = accuracy_score(y_test_final, y_pred_final)
print(f"\n✅ Final Test Accuracy: {test_acc*100:.2f}%")

# ====================== FEATURE IMPORTANCE ======================
xgb.plot_importance(xgb_model, max_num_features=20, importance_type='weight')
plt.title("Top 20 Feature Importances")
plt.show()
#Dumber version of CNN
import pandas as pd
import numpy as np
import tensorflow as tf
from tensorflow import keras
from keras import layers
# import keras_tuner as kt # --- REMOVED ---

import zipfile, os, glob
import re
from tqdm import tqdm

from sklearn.impute import SimpleImputer
from sklearn.preprocessing import StandardScaler, LabelEncoder
from sklearn.model_selection import train_test_split
from sklearn.metrics import classification_report, confusion_matrix
import seaborn as sns
import matplotlib.pyplot as plt

# ================================================
# 1. DATA LOADING (Unchanged)
# ================================================

# --- Ensure this path is correct ---
ZIP_PATH = "/content/Dataset_sdcs.zip"
EXTRACT_DIR = "/content/rtl_sdr_data"
# ----------------------------------

if not os.path.exists(ZIP_PATH):
    print(f"Error: ZIP file not found at {ZIP_PATH}")
    print("Please upload your 'Dataset_sdcs.zip' file to the Colab session content directory.")
else:
    os.makedirs(EXTRACT_DIR, exist_ok=True)
    with zipfile.ZipFile(ZIP_PATH, 'r') as z:
        z.extractall(EXTRACT_DIR)

    csv_files = glob.glob(os.path.join(EXTRACT_DIR, "**", "*.csv"), recursive=True)

    # --- Simplified for speed, no TQDM ---
    dfs = []
    for f in csv_files:
        _df = pd.read_csv(f)
        if 'label' not in _df.columns:
            # --- Simplified label logic from your original ---
            name = os.path.basename(f)
            m = re.search(r"(FM|AM|Airband)", name, re.IGNORECASE)
            _df['label'] = m.group(1) if m else 'Unknown'
        else:
            _df['label'] = _df['label'].astype(str)
        dfs.append(_df)

    full_df = pd.concat(dfs, ignore_index=True)
    full_df = full_df[full_df['label'] != 'Unknown'] # Clean up

    print(f"Combined dataframe shape: {full_df.shape}")
    print("Labels distribution:")
    print(full_df['label'].value_counts())

    cols = full_df.columns.tolist()
    raw_cols = [c for c in cols if re.match(r'^[IQiq]_\d+', c) or re.match(r'^[iIqQ]_\d+', c)]
    print(f"Detected {len(raw_cols)} raw columns.")

    # ================================================
    # 2. PREPROCESSING & SPLITTING (Unchanged)
    # ================================================

    X_raw = full_df[raw_cols].values
    labels = full_df['label'].astype(str).values
    le = LabelEncoder()
    y_encoded = le.fit_transform(labels)

    class_names = list(le.classes_)
    N_CLASSES = len(class_names)
    N_TIMESTEPS = X_raw.shape[1]

    print(f"\nTarget classes: {class_names} (Encoded 0 to {N_CLASSES-1})")
    print(f"Number of timesteps (features): {N_TIMESTEPS}")

    print("Imputing missing values (mean strategy)...")
    raw_imputer = SimpleImputer(strategy='mean')
    X_imputed = raw_imputer.fit_transform(X_raw)

    print("Scaling data (StandardScaler)...")
    scaler_raw = StandardScaler()
    X_scaled = scaler_raw.fit_transform(X_imputed)

    X_train_full, X_test, y_train_full, y_test = train_test_split(
        X_scaled, y_encoded,
        test_size=0.2,
        stratify=y_encoded,
        random_state=42
    )

    X_train_full = X_train_full.astype(np.float32)
    X_test = X_test.astype(np.float32)

    X_train, X_val, y_train, y_val = train_test_split(
        X_train_full, y_train_full,
        test_size=0.2,
        stratify=y_train_full,
        random_state=42
    )

    X_train_reshaped = X_train.reshape((X_train.shape[0], N_TIMESTEPS, 1))
    X_val_reshaped = X_val.reshape((X_val.shape[0], N_TIMESTEPS, 1))
    X_test_reshaped = X_test.reshape((X_test.shape[0], N_TIMESTEPS, 1))

    print(f"\nFinal training data shape: {X_train_reshaped.shape}")
    print(f"Final validation data shape: {X_val_reshaped.shape}")
    print(f"Final testing data shape: {X_test_reshaped.shape}")


    # ================================================
    # 2.5. TF.DATA PIPELINE (--- MODIFIED: AUGMENTATION REMOVED ---)
    # ================================================

    BATCH_SIZE = 32

    print("\nCreating tf.data pipelines (NO augmentation)...")

    # --- NOTE: No .map(augment_signal) ---
    train_ds = tf.data.Dataset.from_tensor_slices((X_train_reshaped, y_train))
    train_ds = (
        train_ds.shuffle(buffer_size=X_train_reshaped.shape[0])
        .batch(BATCH_SIZE)
        .prefetch(tf.data.AUTOTUNE)
    )

    val_ds = tf.data.Dataset.from_tensor_slices((X_val_reshaped, y_val))
    val_ds = (
        val_ds.batch(BATCH_SIZE)
        .prefetch(tf.data.AUTOTUNE)
    )

    test_ds = tf.data.Dataset.from_tensor_slices((X_test_reshaped, y_test))
    test_ds = (
        test_ds.batch(BATCH_SIZE)
        .prefetch(tf.data.AUTOTUNE)
    )

    # ================================================
    # 3. KerasTuner (--- REMOVED ---)
    # ================================================

    # --- NEW: Define a single, "bad" model ---

    def build_simple_model():
        """
        Builds an intentionally simple model with NO regularization
        to demonstrate under-performing and overfitting.
        """
        model = keras.Sequential(name="Simple_Underpowered_Model")
        model.add(layers.Input(shape=(N_TIMESTEPS, 1)))

        # A single, simple Conv block
        model.add(layers.Conv1D(
            filters=32,
            kernel_size=7,
            activation='relu',
            padding='same'
            # --- NO kernel_regularizer ---
        ))
        model.add(layers.MaxPooling1D(pool_size=4, strides=4))
        # --- NO Dropout ---

        # --- NO second Conv block ---

        # --- NO LSTM layer ---

        # We must flatten the output before the Dense layer
        model.add(layers.Flatten())

        # Classifier Head
        model.add(layers.Dense(units=40, activation='relu'))
        # --- NO Dropout ---

        model.add(layers.Dense(units=N_CLASSES, activation='softmax'))

        model.compile(
            optimizer=keras.optimizers.Adam(learning_rate=0.0005),
            loss='sparse_categorical_crossentropy',
            metrics=['accuracy']
        )

        return model

    # ================================================
    # 4. (--- NEW: Build the simple model ---)
    # ================================================

    print("\nBuilding simple, underpowered model...")
    model = build_simple_model()
    model.summary()

    # ================================================
    # 5. FINAL TRAINING & EVALUATION (MODIFIED)
    # ================================================

    print("\nTraining the simple model (expect overfitting)...")

    early_stopper = keras.callbacks.EarlyStopping(
        monitor='val_loss',
        patience=10, # Shorter patience
        restore_best_weights=True
    )

    history = model.fit(
        train_ds, # --- Use NON-augmented train dataset ---
        epochs=100, # Will stop early
        validation_data=val_ds,
        callbacks=[early_stopper]
        # --- NO LR scheduler ---
    )

    # --- Evaluate on the HELD-OUT TEST SET ---
    print("\n--- Final Model Evaluation on Test Set ---")
    score = model.evaluate(test_ds, verbose=1)
    print(f"Test Loss: {score[0]:.4f}")
    print(f"Test Accuracy: {score[1]:.4f}") # <-- This should be lower!

    # --- Classification Report ---
    print("\n--- Classification Report (Test Set) ---")
    y_pred_probs = model.predict(test_ds)
    y_pred = np.argmax(y_pred_probs, axis=1)
    y_test_labels = np.concatenate([y for x, y in test_ds], axis=0)
    print(classification_report(y_test_labels, y_pred, target_names=class_names))

    # --- Confusion Matrix ---
    print("\n--- Confusion Matrix (Test Set) ---")
    cm = confusion_matrix(y_test_labels, y_pred)
    plt.figure(figsize=(8, 6))
    sns.heatmap(
        cm,
        annot=True,
        fmt='d',
        cmap='Blues',
        xticklabels=class_names,
        yticklabels=class_names
    )
    plt.title("Confusion Matrix (Test Set)")
    plt.ylabel('Actual')
    plt.xlabel('Predicted')
    plt.show()

    # --- Plot Training History ---
    print("\n--- Training History ---")
    history_df = pd.DataFrame(history.history)

    plt.figure(figsize=(12, 5))

    plt.subplot(1, 2, 1)
    plt.plot(history_df['accuracy'], label='Train Accuracy')
    plt.plot(history_df['val_accuracy'], label='Validation Accuracy')
    plt.title('Model Accuracy (Overfitting)')
    plt.xlabel('Epoch')
    plt.ylabel('Accuracy')
    plt.legend()

    plt.subplot(1, 2, 2)
    plt.plot(history_df['loss'], label='Train Loss')
    plt.plot(history_df['val_loss'], label='Validation Loss')
    plt.title('Model Loss (Overfitting)')
    plt.xlabel('Epoch')
    plt.ylabel('Loss')
    plt.legend()

    plt.tight_layout()
    plt.show()
  
