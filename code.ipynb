import os
import numpy as np
import pandas as pd
import joblib
import matplotlib.pyplot as plt
import seaborn as sns

from sklearn.model_selection import GroupShuffleSplit, GroupKFold, GridSearchCV
from sklearn.preprocessing import StandardScaler, LabelEncoder
from sklearn.decomposition import PCA
from sklearn.metrics import classification_report, confusion_matrix
from sklearn.svm import SVC

# ---------------------------------
# Paths
# ---------------------------------
DATA_CSV = "/content/processed_dataset/final_pca_dataset.csv"
OUT_DIR = "/content/processed_dataset"
os.makedirs(OUT_DIR, exist_ok=True)

# ---------------------------------
# Load dataset
# ---------------------------------
df = pd.read_csv(DATA_CSV)
print("Loaded dataframe shape:", df.shape)
print(df.head())

# ---------------------------------
# Ensure we have grouping
# ---------------------------------
if "group" in df.columns:
    pass
elif "orig_file" in df.columns:
    df["group"] = df["orig_file"]
else:
    df["group"] = df.groupby("label").cumcount() // 20
    df["group"] = df["label"].astype(str) + "_" + df["group"].astype(str)

# ---------------------------------
# Select PCA features
# ---------------------------------
feature_cols = [c for c in df.columns if c.startswith("PC_")]
X = df[feature_cols].values

# Encode labels
le = LabelEncoder()
y = le.fit_transform(df["label"])
groups = df["group"].values

print("Classes:", le.classes_)
print("X shape:", X.shape)

# ---------------------------------
# Grouped train/test split
# ---------------------------------
gss = GroupShuffleSplit(n_splits=1, test_size=0.20, random_state=42)
train_idx, test_idx = next(gss.split(X, y, groups))

X_train_raw, X_test_raw = X[train_idx], X[test_idx]
y_train, y_test = y[train_idx], y[test_idx]
groups_train = groups[train_idx]

print("Train:", X_train_raw.shape, "Test:", X_test_raw.shape)

# ---------------------------------
# Scaling (fit only on training)
# ---------------------------------
scaler = StandardScaler()
X_train_scaled = scaler.fit_transform(X_train_raw)
X_test_scaled = scaler.transform(X_test_raw)

# ---------------------------------
# PCA (fit only on training)
# ---------------------------------
pca = PCA(n_components=0.95, random_state=42)
X_train_pca = pca.fit_transform(X_train_scaled)
X_test_pca = pca.transform(X_test_scaled)

print("PCA components kept:", pca.n_components_)

# ---------------------------------
# GroupKFold for tuning
# ---------------------------------
gkf = GroupKFold(n_splits=5)

# Hyperparameters that work well for PCA-SVM
param_grid = {
    "C": [0.1, 1, 10],
    "gamma": ["scale", 0.01, 0.001],
    "kernel": ["rbf"]
}

svm = SVC(class_weight="balanced", probability=True)

grid = GridSearchCV(
    svm,
    param_grid,
    scoring="accuracy",
    cv=gkf.split(X_train_pca, y_train, groups_train),
    n_jobs=-1,
    verbose=2
)

print("\n🔍 Running GridSearchCV (this may take a moment)...")
grid.fit(X_train_pca, y_train)

print("\nBest parameters:", grid.best_params_)
print("Best CV accuracy:", grid.best_score_)

# ---------------------------------
# Train best SVM on full training set
# ---------------------------------
best_svm = grid.best_estimator_
best_svm.fit(X_train_pca, y_train)

# ---------------------------------
# Evaluate on true test set
# ---------------------------------
y_pred = best_svm.predict(X_test_pca)
print("\n=========== TEST SET REPORT ===========")
print(classification_report(y_test, y_pred, target_names=le.classes_))

# Confusion Matrix
cm = confusion_matrix(y_test, y_pred)
plt.figure(figsize=(6,4))
sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',
            xticklabels=le.classes_, yticklabels=le.classes_)
plt.xlabel("Predicted")
plt.ylabel("True")
plt.title("Confusion Matrix (SVM Test)")
plt.show()

# ---------------------------------
# Save artifacts
# ---------------------------------
joblib.dump(best_svm, os.path.join(OUT_DIR, "best_svm_model.joblib"))
joblib.dump(scaler, os.path.join(OUT_DIR, "scaler_svm.joblib"))
joblib.dump(pca, os.path.join(OUT_DIR, "pca_svm.joblib"))

print("\nSaved model, scaler, PCA to:", OUT_DIR)
